# Get a free key at https://console.anthropic.com (used to evaluate candidate code & generate feedback)
ANTHROPIC_API_KEY=

# Get a free key at https://rapidapi.com/judge0-official/api/judge0-ce (used to actually run submitted code)
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com
JUDGE0_URL=https://judge0-ce.p.rapidapi.com

# Comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Claude model used for code evaluation
CLAUDE_MODEL=claude-sonnet-5
